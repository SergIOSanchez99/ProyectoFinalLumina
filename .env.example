# Configuración Global del Proyecto

# Base de Datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=redsocial

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Chatbot - API gratuita (prioridad: Groq > Gemini > OpenAI)
# Groq: gratis en https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Gemini: 500 req/día gratis en https://aistudio.google.com/apikey
# GEMINI_API_KEY=xxx
# OpenAI: créditos limitados
# OPENAI_API_KEY=xxx

# URLs de Servicios (para desarrollo local)
API_GATEWAY_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Puertos de Servicios
API_GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
USER_SERVICE_PORT=4002
CONTENT_SERVICE_PORT=4003
COLLABORATION_SERVICE_PORT=4004
REPUTATION_SERVICE_PORT=4005
RECOMMENDATION_SERVICE_PORT=4006
CHATBOT_SERVICE_PORT=4007
